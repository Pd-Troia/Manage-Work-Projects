      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "RWQimUz2TVE8cy+G/z56skz5LTTJFWIVowIuvNYN7qUo1X49XPPVvgHT",
      "endpoints": [
        "https://github.com/Pd-Troia/Manage-Work-Projects/releases/latest/download/latest.json"
      ]
    }
  }
